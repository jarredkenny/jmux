{
  "name": "@jx0/jmux",
  "version": "0.22.0",
  "description": "The terminal workspace for agentic development",
  "type": "module",
  "bin": {
    "jmux": "./bin/jmux"
  },
  "files": [
    "bin",
    "src",
    "config",
    "skills"
  ],
  "scripts": {
    "dev": "bun run src/main.ts",
    "test": "bun test",
    "typecheck": "bun run tsc --noEmit",
    "docker": "docker build -f Dockerfile.test -t jmux-test . && docker run --rm -it jmux-test",
    "test:snapshot-orphan": "docker build -f Dockerfile.snapshot-test -t jmux-snapshot-test . && docker run --rm jmux-snapshot-test",
    "test:snapshot-coverage": "bun run scripts/check-snapshot-coverage.ts"
  },
  "keywords": [
    "tmux",
    "terminal",
    "sidebar",
    "session-manager",
    "tui",
    "cli"
  ],
  "author": "Jarred Kenny",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarredkenny/jmux.git"
  },
  "homepage": "https://github.com/jarredkenny/jmux",
  "engines": {
    "bun": ">=1.3.8"
  },
  "dependencies": {
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.8",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.0"
  }
}
