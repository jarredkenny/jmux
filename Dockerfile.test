FROM debian:bookworm-slim

# Avoid interactive prompts during apt installs
ENV DEBIAN_FRONTEND=noninteractive

# Install curl + unzip (needed to install bun)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl unzip ca-certificates sudo

# Install bun
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

WORKDIR /app

# Copy project files
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile || bun install

COPY . .

# Link jmux into PATH so it works like a real install
RUN bun link

# Auto-launch jmux — tmux/fzf are intentionally NOT installed
# so the onboarding/dependency-install flow can be tested
CMD ["jmux"]
